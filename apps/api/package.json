{
  "name": "@smarttravel/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "prisma": {
    "schema": "../../packages/db/prisma/schema.prisma"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:worker": "tsx watch src/workers/jobs.worker.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "start:worker": "node dist/workers/jobs.worker.js",
    "lint": "echo \"api lint pending\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "format": "echo \"API format\"",
    "prisma:generate": "prisma generate"
  },
  "dependencies": {
    "@fastify/cookie": "^10.0.1",
    "@fastify/cors": "^10.0.2",
    "@fastify/rate-limit": "^10.3.0",
    "@prisma/client": "^5.21.1",
    "@smarttravel/db": "0.1.0",
    "@smarttravel/shared": "0.1.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.16.1",
    "fastify": "^5.1.0",
    "fastify-raw-body": "^5.0.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "stripe": "^17.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.9.0",
    "prisma": "^5.21.1",
    "tsx": "^4.19.2"
  }
}
